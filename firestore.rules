rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return signedIn() && profile().active != false && profile().role in ['admin', 'finance'];
    }
    function isDriver() {
      return signedIn() && profile().active != false && profile().role in ['driver', 'admin', 'finance'];
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if signedIn() && request.auth.uid == uid;
      allow update, delete: if isAdmin();
    }

    match /vehicles/{id} {
      allow read: if isDriver();
      allow write: if isAdmin();
    }

    match /calls/{id} {
      allow read: if isAdmin() || (isDriver() && resource.data.driverId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    match /expenses/{id} {
      allow read: if isAdmin() || (isDriver() && resource.data.driverId == request.auth.uid);
      allow create: if isDriver() && request.resource.data.driverId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /transactions/{id} {
      allow read, write: if isAdmin();
    }

    match /settings/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
