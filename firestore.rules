rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function email() {
      return request.auth.token.email;
    }
    function bootstrapAdminEmail() {
      return signedIn() && email() in [
        'jmguinchos@ts.com',
        'tsvalencio@gmail.com'
      ];
    }
    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return signedIn() && profile().active != false && profile().role in ['admin', 'finance', 'superadmin', 'gestor'];
    }
    function isDriver() {
      return signedIn() && profile().active != false && profile().role in ['driver', 'motorista', 'admin', 'finance', 'superadmin', 'gestor'];
    }
    function managerPermit() {
      return signedIn()
        && exists(/databases/$(database)/documents/managerAccess/$(email()))
        && get(/databases/$(database)/documents/managerAccess/$(email())).data.active != false
        && get(/databases/$(database)/documents/managerAccess/$(email())).data.role in ['admin', 'finance', 'superadmin', 'gestor'];
    }
    function ownAdminRepair(uid) {
      return signedIn()
        && request.auth.uid == uid
        && (bootstrapAdminEmail() || managerPermit())
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == email()
        && request.resource.data.active == true
        && request.resource.data.role in ['admin', 'finance'];
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if signedIn() && (request.auth.uid == uid || isAdmin() || ownAdminRepair(uid));
      allow update: if isAdmin() || ownAdminRepair(uid);
      allow delete: if isAdmin();
    }

    match /managerAccess/{emailId} {
      allow read: if signedIn() && (emailId == email() || isAdmin() || bootstrapAdminEmail());
      allow create, update, delete: if isAdmin() || bootstrapAdminEmail();
    }

    match /vehicles/{id} {
      allow read: if isDriver();
      allow write: if isAdmin();
    }

    match /calls/{id} {
      allow read: if isAdmin() || (isDriver() && resource.data.driverId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    match /expenses/{id} {
      allow read: if isAdmin() || (isDriver() && resource.data.driverId == request.auth.uid);
      allow create: if isDriver() && request.resource.data.driverId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /transactions/{id} {
      allow read, write: if isAdmin();
    }

    match /settings/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
